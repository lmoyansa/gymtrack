<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gt_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/gt_screen_padding">

        <TextView
            style="@style/GymTrack_Overline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENTRENAMIENTO ACTIVO" />

        <TextView
            android:id="@+id/tvNombreRutinaEntrenamiento"
            style="@style/GymTrack_Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_small"
            android:text="Nombre de la rutina" />

        <TextView
            android:id="@+id/tvResumenEntrenamiento"
            style="@style/GymTrack_Muted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_small"
            android:text="Introduce los resultados y marca las series completadas." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_large"
            android:background="@drawable/gt_background_card"
            android:orientation="vertical"
            android:padding="@dimen/gt_card_padding">

            <TextView
                style="@style/GymTrack_Overline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DURACIÓN DEL ENTRENAMIENTO" />

            <TextView
                android:id="@+id/tvDuracionEntrenamiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gt_gap_small"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:text="00:00"
                android:textAlignment="center"
                android:textColor="@color/gt_foreground"
                android:textSize="42sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAbrirTemporizadorEntrenamiento"
                style="@style/GymTrack_Button_Secondary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/gt_button_height"
                android:layout_marginTop="@dimen/gt_gap_medium"
                android:text="Abrir temporizador de descanso" />

        </LinearLayout>

        <TextView
            style="@style/GymTrack_SectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_large"
            android:text="Registro de series" />

        <LinearLayout
            android:id="@+id/contenedorRegistroEjercicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_medium"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_small"
            android:background="@drawable/gt_background_card"
            android:orientation="vertical"
            android:padding="@dimen/gt_card_padding">

            <TextView
                style="@style/GymTrack_SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Observaciones" />

            <TextView
                style="@style/GymTrack_Muted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gt_gap_small"
                android:layout_marginBottom="@dimen/gt_gap_medium"
                android:text="Añade cualquier comentario sobre el entrenamiento." />

            <EditText
                android:id="@+id/etObservacionesEntrenamiento"
                style="@style/GymTrack_Input_Multiline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:hint="Ej. Buenas sensaciones, última serie cerca del fallo..."
                android:inputType="textCapSentences|textMultiLine"
                android:minLines="3" />

        </LinearLayout>

        <Button
            android:id="@+id/btnFinalizarEntrenamiento"
            style="@style/GymTrack_Button_Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/gt_button_height"
            android:layout_marginTop="@dimen/gt_gap_large"
            android:text="Finalizar entrenamiento" />

        <Button
            android:id="@+id/btnCancelarEntrenamiento"
            style="@style/GymTrack_Button_Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/gt_button_height"
            android:layout_marginTop="@dimen/gt_gap_medium"
            android:text="Cancelar entrenamiento" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="@dimen/gt_gap_large" />

    </LinearLayout>

</ScrollView>