<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gt_background"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/gt_screen_padding">

        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp" />

        <TextView
            style="@style/GymTrack_Overline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GYMTRACK" />

        <TextView
            android:id="@+id/tvTitulo"
            style="@style/GymTrack_Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_small"
            android:gravity="center"
            android:text="ENTRENA. REGISTRA. PROGRESA."
            android:textAlignment="center"
            android:textSize="38sp" />

        <TextView
            android:id="@+id/tvSubtitulo"
            style="@style/GymTrack_Muted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_medium"
            android:gravity="center"
            android:text="Gestiona tus rutinas y registra cada entrenamiento desde un único lugar."
            android:textAlignment="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:background="@drawable/gt_background_card"
            android:orientation="vertical"
            android:padding="@dimen/gt_card_padding">

            <TextView
                style="@style/GymTrack_SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accesos rápidos" />

            <TextView
                style="@style/GymTrack_Muted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gt_gap_small"
                android:layout_marginBottom="@dimen/gt_gap_large"
                android:text="Selecciona qué parte de tu entrenamiento quieres gestionar." />

            <Button
                android:id="@+id/btnMisRutinas"
                style="@style/GymTrack_Button_Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/gt_button_height"
                android:text="Mis rutinas" />

            <Button
                android:id="@+id/btnIniciarEntrenamiento"
                style="@style/GymTrack_Button_Secondary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/gt_button_height"
                android:layout_marginTop="@dimen/gt_gap_medium"
                android:text="Iniciar entrenamiento" />

            <Button
                android:id="@+id/btnHistorial"
                style="@style/GymTrack_Button_Secondary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/gt_button_height"
                android:layout_marginTop="@dimen/gt_gap_medium"
                android:text="Historial" />

            <Button
                android:id="@+id/btnTemporizador"
                style="@style/GymTrack_Button_Secondary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/gt_button_height"
                android:layout_marginTop="@dimen/gt_gap_medium"
                android:text="Temporizador" />

        </LinearLayout>

        <TextView
            style="@style/GymTrack_Muted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_large"
            android:gravity="center"
            android:text="Tu progreso empieza con la siguiente serie."
            android:textAlignment="center"
            android:textSize="13sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>

</ScrollView>