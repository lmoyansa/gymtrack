<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gt_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/gt_screen_padding">

        <TextView
            style="@style/GymTrack_Overline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DESCANSO" />

        <TextView
            style="@style/GymTrack_Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_small"
            android:text="Temporizador" />

        <TextView
            style="@style/GymTrack_Muted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_small"
            android:text="Controla el tiempo de descanso entre series." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_large"
            android:background="@drawable/gt_background_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/tvEstadoTemporizador"
                style="@style/GymTrack_Overline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LISTO PARA EMPEZAR" />

            <TextView
                android:id="@+id/tvTiempoTemporizador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/gt_gap_medium"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:letterSpacing="0.04"
                android:text="01:30"
                android:textAlignment="center"
                android:textColor="@color/gt_foreground"
                android:textSize="72sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            style="@style/GymTrack_SectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_large"
            android:text="Tiempo de descanso" />

        <TextView
            style="@style/GymTrack_Muted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_small"
            android:text="Selecciona una duración rápida." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/gt_gap_medium"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTiempo60"
                style="@style/GymTrack_Button_Secondary"
                android:layout_width="0dp"
                android:layout_height="@dimen/gt_button_height"
                android:layout_weight="1"
                android:text="60 s" />

            <Button
                android:id="@+id/btnTiempo90"
                style="@style/GymTrack_Button_Secondary"
                android:layout_width="0dp"
                android:layout_height="@dimen/gt_button_height"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="90 s" />

            <Button
                android:id="@+id/btnTiempo120"
                style="@style/GymTrack_Button_Secondary"
                android:layout_width="0dp"
                android:layout_height="@dimen/gt_button_height"
                android:layout_weight="1"
                android:text="120 s" />

        </LinearLayout>

        <Button
            android:id="@+id/btnIniciarPausarTemporizador"
            style="@style/GymTrack_Button_Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/gt_button_height"
            android:layout_marginTop="@dimen/gt_gap_large"
            android:text="Iniciar" />

        <Button
            android:id="@+id/btnReiniciarTemporizador"
            style="@style/GymTrack_Button_Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/gt_button_height"
            android:layout_marginTop="@dimen/gt_gap_medium"
            android:text="Reiniciar" />

        <Button
            android:id="@+id/btnVolverInicioTemporizador"
            style="@style/GymTrack_Button_Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/gt_button_height"
            android:layout_marginTop="@dimen/gt_gap_medium"
            android:text="Volver al inicio" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="@dimen/gt_gap_large" />

    </LinearLayout>

</ScrollView>