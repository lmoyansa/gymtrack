<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <shape android:shape="rectangle">

            <solid android:color="@color/gt_secondary" />

            <stroke
                android:width="1dp"
                android:color="@color/gt_primary" />

            <corners android:radius="@dimen/gt_input_radius" />

        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">

            <solid android:color="@color/gt_secondary" />

            <stroke
                android:width="1dp"
                android:color="@color/gt_border" />

            <corners android:radius="@dimen/gt_input_radius" />

        </shape>
    </item>

</selector>