<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutRutinas"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F4F6F8">

    <TextView
        android:id="@+id/tvTituloRutinas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mis rutinas"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1E1E1E"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnCrearRutina"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Crear nueva rutina"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvMensajeVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Todavía no tienes rutinas creadas."
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginBottom="16dp" />

    <ScrollView
        android:id="@+id/scrollRutinas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/contenedorRutinas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

    <Button
        android:id="@+id/btnVolverHome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Volver" />

</LinearLayout>