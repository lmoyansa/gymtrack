<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#F4F6F8">

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GymTrack"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#1E1E1E"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvSubtitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gestiona tus rutinas y sigue tu progreso"
        android:textSize="16sp"
        android:gravity="center"
        android:textColor="#555555"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnMisRutinas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mis rutinas"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnIniciarEntrenamiento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Iniciar entrenamiento"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Historial"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnTemporizador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Temporizador" />

</LinearLayout>