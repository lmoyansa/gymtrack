<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutEditarRutina"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F4F6F8">

    <TextView
        android:id="@+id/tvTituloEditarRutina"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Editar rutina"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1E1E1E"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/etNombreRutinaEditar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre de la rutina"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etDescripcionRutinaEditar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Descripción"
        android:inputType="textMultiLine"
        android:minLines="2"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etObjetivoRutinaEditar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Objetivo: hipertrofia, fuerza, mantenimiento..."
        android:inputType="text"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnGuardarCambiosRutina"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guardar cambios"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnCancelarEditarRutina"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancelar" />

</LinearLayout>